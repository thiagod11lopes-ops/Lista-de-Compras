# Firebase (Console → Definições do projeto → As tuas apps → Configuração do SDK)
# Copie para .env na raiz e reinicie `npm run dev`.
# Ative o Firestore em modo de teste ou publique regras (ver firestore.rules).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Opcionais (geralmente preenchidos pelo snippet do Firebase)
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
